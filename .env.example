# Resend — transactional email for the quote/contact form.
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=

# Verified "from" sender. Until the CASEMEX domain is verified in Resend,
# leave this on the sandbox sender below (works out of the box for testing).
# Once casemex.com.mx (or chosen domain) is verified, switch to e.g.
# CONTACT_FROM="CASEMEX <cotizaciones@casemex.com.mx>"
CONTACT_FROM="CASEMEX <onboarding@resend.dev>"

# Where quote requests are delivered.
CONTACT_TO="eduardo.casemex@gmail.com"

# Public site URL (used for metadata, canonical, sitemap, OG).
NEXT_PUBLIC_SITE_URL="https://casemex.com.mx"

# WhatsApp number in international format WITHOUT + or spaces (e.g. 5219621078960).
# Leave empty to hide WhatsApp buttons until the number is confirmed.
NEXT_PUBLIC_WHATSAPP=""
